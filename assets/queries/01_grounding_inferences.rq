# CQ1: Which textual fragments and cues ground the interpretive inferences modeled in the Knowledge Graph?
# Purpose: Check that interpretive inferences are grounded in textual fragments and textual cues.
# KG pattern: TextFragment -> containsCue -> TextualCue -> supportsInference -> Inference
# Expected result: A table listing textual fragments, cues, and inferences across the four interpretive cases.

PREFIX lig: <https://lectoringraphula.org/ontology#>
PREFIX hmt: <https://lectoringraphula.org/handmaid#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?fragmentLabel ?source ?cueLabel ?cueText ?inferenceLabel
WHERE {
  ?fragment lig:containsCue ?cue .
  ?cue lig:supportsInference ?inference .

  OPTIONAL { ?fragment rdfs:label ?fragmentLabel . }
  OPTIONAL { ?fragment lig:hasSourceReference ?source . }
  OPTIONAL { ?cue rdfs:label ?cueLabel . }
  OPTIONAL { ?cue lig:hasTextualContent ?cueText . }
  OPTIONAL { ?inference rdfs:label ?inferenceLabel . }
}
ORDER BY ?fragmentLabel ?cueLabel ?inferenceLabel
