# CQ3: Which presuppositions are triggered by textual cues?
# Purpose: Check which implicit presuppositions are activated by each textual cue.
# KG pattern: TextualCue -> triggersPresupposition -> Presupposition
# Expected result: A table listing textual cues and the presuppositions they trigger.

PREFIX lig: <https://lectoringraphula.org/ontology#>
PREFIX hmt: <https://lectoringraphula.org/handmaid#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?fragmentLabel ?cueLabel ?cueText ?presuppositionLabel
WHERE {
  ?fragment lig:containsCue ?cue .
  ?cue lig:triggersPresupposition ?presupposition .

  OPTIONAL { ?fragment rdfs:label ?fragmentLabel . }
  OPTIONAL { ?cue rdfs:label ?cueLabel . }
  OPTIONAL { ?cue lig:hasTextualContent ?cueText . }
  OPTIONAL { ?presupposition rdfs:label ?presuppositionLabel . }
}
ORDER BY ?fragmentLabel ?cueLabel ?presuppositionLabel
