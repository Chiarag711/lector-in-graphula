# NCQ1: Are empirical readers or empirical authors treated as Model Reader or Model Author?
# Expected answer: No.
# Purpose: Check that ModelReader and ModelAuthor are not confused with empirical readers or empirical authors.
# KG pattern: ModelReader should not overlap with EmpiricalReader; ModelAuthor should not overlap with EmpiricalAuthor.
# Expected result: 0 rows.

PREFIX lig: <https://lectoringraphula.org/ontology#>
PREFIX hmt: <https://lectoringraphula.org/handmaid#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?entityLabel
WHERE {
  {
    ?entity rdf:type lig:ModelReader .
    ?entity rdf:type lig:EmpiricalReader .
  }
  UNION
  {
    ?entity rdf:type lig:ModelAuthor .
    ?entity rdf:type lig:EmpiricalAuthor .
  }

  OPTIONAL { ?entity rdfs:label ?entityLabel . }
}
ORDER BY ?entityLabel
