# CQ2: Which textual cues require intrinsic knowledge?
# Purpose: Check which implicit knowledge is required by each textual cue.
# KG pattern: TextualCue -> requiresIntrinsicKnowledge -> IntrinsicKnowledge
# Expected result: A table listing textual cues and the intrinsic knowledge required to interpret them.

PREFIX lig: <https://lectoringraphula.org/ontology#>
PREFIX hmt: <https://lectoringraphula.org/handmaid#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?fragmentLabel ?cueLabel ?cueText ?knowledgeLabel
WHERE {
  ?fragment lig:containsCue ?cue .
  ?cue lig:requiresIntrinsicKnowledge ?knowledge .

  OPTIONAL { ?fragment rdfs:label ?fragmentLabel . }
  OPTIONAL { ?cue rdfs:label ?cueLabel . }
  OPTIONAL { ?cue lig:hasTextualContent ?cueText . }
  OPTIONAL { ?knowledge rdfs:label ?knowledgeLabel . }
}
ORDER BY ?fragmentLabel ?cueLabel ?knowledgeLabel
