# CQ8: Which Model Reader strategies or levels are presupposed by the narrative text?
# Purpose: Check which Model Reader strategies are presupposed by the text.
# KG pattern: Text -> presupposesModelReader -> ModelReader
# Expected result: A table listing the narrative text and its presupposed Model Reader strategies or levels.

PREFIX lig: <https://lectoringraphula.org/ontology#>
PREFIX hmt: <https://lectoringraphula.org/handmaid#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?textLabel ?modelReaderLabel
WHERE {
  ?text lig:presupposesModelReader ?modelReader .

  OPTIONAL { ?text rdfs:label ?textLabel . }
  OPTIONAL { ?modelReader rdfs:label ?modelReaderLabel . }
}
ORDER BY ?textLabel ?modelReaderLabel
