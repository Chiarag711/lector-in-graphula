@prefix : <https://lectoringraphula.org/ontology#> .
@prefix lig: <https://lectoringraphula.org/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix var: <urn:swrl:var#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@base <https://lectoringraphula.org/ontology#> .

<https://chiarag711.github.io/lector-in-graphula/ontology/econtology.ttl> rdf:type owl:Ontology ;
                                                                           <http://purl.org/dc/elements/1.1/creator> "Chiara Genovese, Asia Marselli, Adriana Monte"@en ;
                                                                           <http://purl.org/dc/elements/1.1/description> "An ontology formalizing Umberto Eco's theory of interpretive cooperation from \"Lector in Fabula\", instantiated with excerpts from \"The Handmaid's Tale\" as a case study."@en ;
                                                                           rdfs:comment "This ontology provides the theoretical schema of the Lector in Graphula project. It formalizes key concepts from Umberto Eco's \"Lector in Fabula\", including Model Author, Model Reader, textual cues, gaps, encyclopedia, codes, frames, intrinsic knowledge, inferential walks, possible worlds, and the distinction between interpretation and use. The ontology is designed as a reusable TBox and is later instantiated through a separate knowledge graph based on selected excerpts from \"The Handmaid's Tale\"."@en ;
                                                                           rdfs:label "Econtology"@en ;
                                                                           owl:versionInfo "0.1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#argument1
swrl:argument1 rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#argument2
swrl:argument2 rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#body
swrl:body rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#head
swrl:head rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#propertyPredicate
swrl:propertyPredicate rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://lectoringraphula.org/ontology#activatesCode
lig:activatesCode rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf lig:activatesResource ;
                  rdfs:domain lig:TextualCue ,
                              lig:TextualEntity ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty lig:activatesResource ;
                                owl:someValuesFrom lig:InterpretiveResource
                              ] ;
                  rdfs:range lig:Code ,
                             lig:InterpretiveResource ;
                  <http://purl.org/dc/elements/1.1/description> "Links a textual cue to the semiotic code it activates."@en ;
                  rdfs:comment "This property connects a TextualCue to the Code or Subcode needed to decode it. Codes are shared interpretive conventions that make textual communication possible. For example, a color, formula, genre marker, or recurring expression may activate a specific cultural, rhetorical, ideological, or narrative code."@en ;
                  rdfs:label "activates code"@en .


###  https://lectoringraphula.org/ontology#activatesEncyclopedia
lig:activatesEncyclopedia rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf lig:activatesResource ;
                          rdfs:domain lig:TextualCue ,
                                      lig:TextualEntity ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty lig:activatesResource ;
                                        owl:someValuesFrom lig:InterpretiveResource
                                      ] ;
                          rdfs:range lig:Encyclopedia ,
                                     lig:InterpretiveResource ;
                          <http://purl.org/dc/elements/1.1/description> "Links a textual cue to the encyclopedic knowledge it activates."@en ;
                          rdfs:comment "This property connects a TextualCue to the Encyclopedia it activates. The encyclopedia is the network of cultural and world knowledge that a reader can draw on. A textual cue activates the relevant portion of this knowledge needed for interpretation."@en ;
                          rdfs:label "activates encyclopedia"@en .


###  https://lectoringraphula.org/ontology#activatesFrame
lig:activatesFrame rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf lig:activatesResource ;
                   rdfs:domain lig:TextualCue ,
                               lig:TextualEntity ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty lig:activatesResource ;
                                 owl:someValuesFrom lig:InterpretiveResource
                               ] ;
                   rdfs:range lig:Frame ,
                              lig:InterpretiveResource ;
                   <http://purl.org/dc/elements/1.1/description> "Links a textual cue to the cognitive frame it activates."@en ;
                   rdfs:comment "This property connects a TextualCue to the Frame it activates in the reader. A frame is a structure of background knowledge that helps the reader organize and interpret a signal in the text. For example, a ritual formula, an institutional title, or a symbolic expression may activate a religious, political, social, or narrative frame."@en ;
                   rdfs:label "activates frame"@en .


###  https://lectoringraphula.org/ontology#activatesResource
lig:activatesResource rdf:type owl:ObjectProperty ;
                      rdfs:domain lig:TextualCue ,
                                  lig:TextualEntity ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty lig:activatesResource ;
                                    owl:someValuesFrom lig:InterpretiveResource
                                  ] ;
                      rdfs:range lig:InterpretiveResource ;
                      <http://purl.org/dc/elements/1.1/description> "Links a textual cue to the interpretive resource it activates."@en ;
                      rdfs:comment "This property connects a TextualCue to an InterpretiveResource. When a reader encounters a cue, they draw on resources such as codes, frames and encyclopedic knowledge to interpret it. This is the most general activation property."@en ;
                      rdfs:label "activates resource"@en .


###  https://lectoringraphula.org/ontology#allowsAlternativeInterpretation
lig:allowsAlternativeInterpretation rdf:type owl:ObjectProperty ;
                                    rdfs:domain lig:OpenText ,
                                                lig:Text ,
                                                lig:TextualEntity ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty lig:encodesModelAuthor ;
                                                  owl:someValuesFrom lig:ModelAuthor
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty lig:presupposesModelReader ;
                                                  owl:someValuesFrom lig:ModelReader
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty lig:requiresCompetence ;
                                                  owl:someValuesFrom lig:ReaderCompetence
                                                ] ;
                                    rdfs:range lig:AlternativeInterpretation ,
                                               lig:Interpretation ,
                                               lig:InterpretiveOutcome ;
                                    <http://purl.org/dc/elements/1.1/description> "Links an open text to the alternative interpretations it allows."@en ;
                                    rdfs:comment "This property connects an OpenText to the AlternativeInterpretation it allows. Open texts are designed to support multiple valid readings at the same time. This property captures the deliberate openness that Eco identifies in literary texts."@en ;
                                    rdfs:label "allows alternative interpretation"@en .


###  https://lectoringraphula.org/ontology#constrainsInterpretation
lig:constrainsInterpretation rdf:type owl:ObjectProperty ;
                             rdfs:domain lig:ModelAuthor ,
                                         lig:TextualStrategy ;
                             rdfs:range lig:Interpretation ,
                                        lig:InterpretiveOutcome ;
                             <http://purl.org/dc/elements/1.1/description> "Links the model author to the interpretation it constrains."@en ;
                             rdfs:comment "This property connects a ModelAuthor to the Interpretation it constrains. The Model Author sets the limits of what the text can legitimately mean. Not all readings are valid and this property models the boundary between a correct interpretation and an arbitrary use of the text."@en ;
                             rdfs:label "constrains interpretation"@en .


###  https://lectoringraphula.org/ontology#constructsPossibleWorld
lig:constructsPossibleWorld rdf:type owl:ObjectProperty ;
                            rdfs:domain lig:InferentialWalk ,
                                        lig:InterpretiveOperation ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty lig:constructsPossibleWorld ;
                                          owl:someValuesFrom lig:PossibleWorld
                                        ] ;
                            rdfs:range lig:NarrativeConstruction ,
                                       lig:PossibleWorld ;
                            <http://purl.org/dc/elements/1.1/description> "Links an inferential walk to the possible world it constructs."@en ;
                            rdfs:comment "This property connects an InferentialWalk to the PossibleWorld it constructs. As the reader follows an inferential path through the text, they build up a hypothetical world, a mental model of the narrative situation at a given point in the story."@en ;
                            rdfs:label "constructs possible world"@en .


###  https://lectoringraphula.org/ontology#containsCue
lig:containsCue rdf:type owl:ObjectProperty ;
                rdfs:domain lig:TextFragment ,
                            lig:TextualEntity ;
                rdfs:range lig:TextualCue ,
                           lig:TextualEntity ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty lig:activatesResource ;
                             owl:someValuesFrom lig:InterpretiveResource
                           ] ;
                <http://purl.org/dc/elements/1.1/description> "Links a text fragment to a textual cue it contains."@en ;
                rdfs:comment "This property connects a TextFragment to a TextualCue. A textual cue is a word, phrase, stylistic feature, omission, or structural signal in the text that activates the reader's interpretive resources. For example, a proper name, a repeated formula, or a symbolic detail may function as a cue that activates knowledge beyond the explicit textual surface."@en ;
                rdfs:label "contains cue"@en .


###  https://lectoringraphula.org/ontology#containsGap
lig:containsGap rdf:type owl:ObjectProperty ;
                rdfs:domain lig:TextFragment ,
                            lig:TextualEntity ;
                rdfs:range lig:Gap ,
                           lig:TextualEntity ;
                <http://purl.org/dc/elements/1.1/description> "Links a text fragment to one of its gaps."@en ;
                rdfs:comment "This property connects a TextFragment to a Gap. A gap is something the text leaves unsaid that the reader must fill in through inference and background knowledge. This is what Eco means when he calls the text a lazy machine."@en ;
                rdfs:label "contains gap"@en .


###  https://lectoringraphula.org/ontology#containsIndividual
lig:containsIndividual rdf:type owl:ObjectProperty ;
                       rdfs:domain lig:NarrativeConstruction ,
                                   lig:WorldState ;
                       rdfs:range lig:NarrativeConstruction ,
                                  lig:WorldIndividual ;
                       <http://purl.org/dc/elements/1.1/description> "Links a world state to one of its individuals."@en ;
                       rdfs:comment "This property connects a WorldState to a WorldIndividual. A world individual is a character, object or entity that exists in the narrative world at that state. The same individual may have different properties across different world states."@en ;
                       rdfs:label "contains individual"@en .


###  https://lectoringraphula.org/ontology#contributesToInterpretation
lig:contributesToInterpretation rdf:type owl:ObjectProperty ;
                                rdfs:domain lig:TextualCue ,
                                            lig:TextualEntity ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty lig:activatesResource ;
                                              owl:someValuesFrom lig:InterpretiveResource
                                            ] ;
                                rdfs:range lig:Interpretation ,
                                           lig:InterpretiveOutcome ;
                                <http://purl.org/dc/elements/1.1/description> "Relates a textual cue to an interpretation that is licensed through an inference supported by that cue."@en ;
                                rdfs:comment "This property makes explicit the contribution of a textual cue to an interpretation through the intermediate inference it supports."@en ;
                                rdfs:label "contributes to interpretation"@en .


###  https://lectoringraphula.org/ontology#encodesModelAuthor
lig:encodesModelAuthor rdf:type owl:ObjectProperty ;
                       rdfs:domain lig:Text ,
                                   lig:TextualEntity ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty lig:encodesModelAuthor ;
                                     owl:someValuesFrom lig:ModelAuthor
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty lig:presupposesModelReader ;
                                     owl:someValuesFrom lig:ModelReader
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty lig:requiresCompetence ;
                                     owl:someValuesFrom lig:ReaderCompetence
                                   ] ;
                       rdfs:range lig:ModelAuthor ,
                                  lig:TextualStrategy ;
                       <http://purl.org/dc/elements/1.1/description> "Links a text to the model author encoded within it."@en ;
                       rdfs:comment "This property connects a Text to the ModelAuthor encoded in it. The Model Author is not the real person who wrote the text but the set of rules and instructions that guide the reader toward a correct interpretation."@en ;
                       rdfs:label "encodes model author"@en .


###  https://lectoringraphula.org/ontology#generatesPrediction
lig:generatesPrediction rdf:type owl:ObjectProperty ;
                        rdfs:domain lig:Inference ,
                                    lig:InterpretiveOperation ;
                        rdfs:range lig:InterpretiveOperation ,
                                   lig:Prediction ;
                        <http://purl.org/dc/elements/1.1/description> "Links an inference to the prediction it generates"@en ;
                        rdfs:comment "This property connects an Inference to the Prediction it generates. As the reader draws inferences, they form predictions about what will happen next in the narrative. These predictions are held provisionally and tested against the rest of the text."@en ;
                        rdfs:label "generates prediction"@en .


###  https://lectoringraphula.org/ontology#groundsInference
lig:groundsInference rdf:type owl:ObjectProperty ;
                     rdfs:domain lig:TextFragment ,
                                 lig:TextualEntity ;
                     rdfs:range lig:Inference ,
                                lig:InterpretiveOperation ;
                     <http://purl.org/dc/elements/1.1/description> "Relates a textual fragment to an inference grounded in a textual cue contained in that fragment."@en ;
                     rdfs:comment "This property is intended to be inferred by a SWRL rule from the chain TextFragment containsCue TextualCue and TextualCue supportsInference Inference."@en ;
                     rdfs:label "grounds inference"@en .


###  https://lectoringraphula.org/ontology#hasAccidentalProperty
lig:hasAccidentalProperty rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf lig:hasWorldProperty ;
                          rdfs:domain lig:NarrativeConstruction ,
                                      lig:WorldIndividual ;
                          rdfs:range lig:AccidentalProperty ,
                                     lig:NarrativeConstruction ,
                                     lig:WorldProperty ;
                          <http://purl.org/dc/elements/1.1/description> "Links a world individual to one of its accidental properties."@en ;
                          rdfs:comment "This property connects a WorldIndividual to an AccidentalProperty that may vary across possible worlds without changing the identity of the individual. It specializes hasWorldProperty by indicating that the property is not essential for cross-world identity."@en ;
                          rdfs:label "has accidental property"@en .


###  https://lectoringraphula.org/ontology#hasAlternativePrediction
lig:hasAlternativePrediction rdf:type owl:ObjectProperty ;
                             rdfs:domain lig:InterpretiveOperation ,
                                         lig:ProbabilityDisjunction ;
                             rdfs:range lig:InterpretiveOperation ,
                                        lig:Prediction ;
                             <http://purl.org/dc/elements/1.1/description> "Links a probability disjunction to one of its alternative predictions."@en ;
                             rdfs:comment "This property connects a ProbabilityDisjunction to the alternative predictions considered by the Model Reader. Each prediction represents a possible interpretive development with a certain degree of probability."@en ;
                             rdfs:label "has alternative prediction"@en .


###  https://lectoringraphula.org/ontology#hasEssentialProperty
lig:hasEssentialProperty rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf lig:hasWorldProperty ;
                         rdfs:domain lig:NarrativeConstruction ,
                                     lig:WorldIndividual ;
                         rdfs:range lig:EssentialProperty ,
                                    lig:NarrativeConstruction ,
                                    lig:WorldProperty ;
                         <http://purl.org/dc/elements/1.1/description> "Links a world individual to one of its essential properties."@en ;
                         rdfs:comment "This property connects a WorldIndividual to an EssentialProperty that contributes to its identity across possible worlds. It specializes hasWorldProperty by indicating that the property is necessary for recognizing the individual as the same variant across worlds."@en ;
                         rdfs:label "has essential property"@en .


###  https://lectoringraphula.org/ontology#hasFragment
lig:hasFragment rdf:type owl:ObjectProperty ;
                rdfs:domain lig:Text ,
                            lig:TextualEntity ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty lig:encodesModelAuthor ;
                              owl:someValuesFrom lig:ModelAuthor
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty lig:presupposesModelReader ;
                              owl:someValuesFrom lig:ModelReader
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty lig:requiresCompetence ;
                              owl:someValuesFrom lig:ReaderCompetence
                            ] ;
                rdfs:range lig:TextFragment ,
                           lig:TextualEntity ;
                <http://purl.org/dc/elements/1.1/description> "Links a text to one of its fragments."@en ;
                rdfs:comment "This property connects a Text to a TextFragment. A fragment is a specific portion of the text selected for interpretive analysis, such as a chapter or a passage."@en ;
                rdfs:label "has fragment"@en .


###  https://lectoringraphula.org/ontology#hasLinearManifestation
lig:hasLinearManifestation rdf:type owl:ObjectProperty ;
                           rdfs:domain lig:Text ,
                                       lig:TextualEntity ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty lig:encodesModelAuthor ;
                                         owl:someValuesFrom lig:ModelAuthor
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty lig:presupposesModelReader ;
                                         owl:someValuesFrom lig:ModelReader
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty lig:requiresCompetence ;
                                         owl:someValuesFrom lig:ReaderCompetence
                                       ] ;
                           rdfs:range lig:LinearManifestation ,
                                      lig:TextualEntity ;
                           <http://purl.org/dc/elements/1.1/description> "Links a text to its linear manifestation."@en ;
                           rdfs:comment "This property connects a Text to its LinearManifestation. The linear manifestation is the concrete sequence of words on the page, before any interpretation takes place."@en ;
                           rdfs:label "has linear manifestation"@en .


###  https://lectoringraphula.org/ontology#hasReferenceWorld
lig:hasReferenceWorld rdf:type owl:ObjectProperty ;
                      rdfs:domain lig:NarrativeConstruction ,
                                  lig:PossibleWorld ;
                      rdfs:range lig:NarrativeConstruction ,
                                 lig:PossibleWorld ,
                                 lig:ReferenceWorld ;
                      <http://purl.org/dc/elements/1.1/description> "Links a possible world to the reference world it is evaluated against."@en ;
                      rdfs:comment "This property connects a PossibleWorld to its ReferenceWorld. The reference world is the baseline world that the reader uses to evaluate alternative possible worlds for consistency and truth. It is usually the established narrative world or the actual world."@en ;
                      rdfs:label "has reference world"@en .


###  https://lectoringraphula.org/ontology#hasSNecessaryProperty
lig:hasSNecessaryProperty rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf lig:hasWorldProperty ;
                          rdfs:domain lig:NarrativeConstruction ,
                                      lig:WorldIndividual ;
                          rdfs:range lig:NarrativeConstruction ,
                                     lig:SNecessaryProperty ,
                                     lig:WorldProperty ;
                          <http://purl.org/dc/elements/1.1/description> "Links a world individual to one of its S-necessary properties."@en ;
                          rdfs:comment "This property connects a WorldIndividual to an SNecessaryProperty that is necessary within a specific world state. It specializes hasWorldProperty by indicating that the property depends on a particular configuration or situation inside a possible world."@en ;
                          rdfs:label "has S-necessary property"@en .


###  https://lectoringraphula.org/ontology#hasWorldProperty
lig:hasWorldProperty rdf:type owl:ObjectProperty ;
                     rdfs:domain lig:NarrativeConstruction ,
                                 lig:WorldIndividual ;
                     rdfs:range lig:NarrativeConstruction ,
                                lig:WorldProperty ;
                     <http://purl.org/dc/elements/1.1/description> "Links a world individual to one of its properties."@en ;
                     rdfs:comment "This property connects a WorldIndividual to a WorldProperty attributed to it within a possible world or world state."@en ;
                     rdfs:label "has world property"@en .


###  https://lectoringraphula.org/ontology#hasWorldState
lig:hasWorldState rdf:type owl:ObjectProperty ;
                  rdfs:domain lig:NarrativeConstruction ,
                              lig:PossibleWorld ;
                  rdfs:range lig:NarrativeConstruction ,
                             lig:WorldState ;
                  <http://purl.org/dc/elements/1.1/description> "Links a possible world to one of its states."@en ;
                  rdfs:comment "This property connects a PossibleWorld to a WorldState. A world state is a specific configuration of individuals and properties at a particular moment in the narrative. World states allow the reader to track changes and evaluate the consistency of the story over time."@en ;
                  rdfs:label "has world state"@en .


###  https://lectoringraphula.org/ontology#holdsInWorldState
lig:holdsInWorldState rdf:type owl:ObjectProperty ;
                      rdfs:domain lig:NarrativeConstruction ,
                                  lig:WorldProperty ;
                      rdfs:range lig:NarrativeConstruction ,
                                 lig:WorldState ;
                      <http://purl.org/dc/elements/1.1/description> "Links a world property to the world state in which it holds."@en ;
                      rdfs:comment "This property connects a WorldProperty to the WorldState in which it is valid. It is especially useful for modeling S-necessary properties, since their necessity depends on a specific state or configuration of a possible world."@en ;
                      rdfs:label "holds in world state"@en .


###  https://lectoringraphula.org/ontology#initiatesInferentialWalk
lig:initiatesInferentialWalk rdf:type owl:ObjectProperty ;
                             rdfs:domain lig:TextualCue ,
                                         lig:TextualEntity ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty lig:activatesResource ;
                                           owl:someValuesFrom lig:InterpretiveResource
                                         ] ;
                             rdfs:range lig:InferentialWalk ,
                                        lig:InterpretiveOperation ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty lig:constructsPossibleWorld ;
                                          owl:someValuesFrom lig:PossibleWorld
                                        ] ;
                             <http://purl.org/dc/elements/1.1/description> "Links a textual cue to the inferential walk it initiates."@en ;
                             rdfs:comment "This property connects a TextualCue to the InferentialWalk it initiates. An inferential walk is a provisional path of interpretation that the reader begins to follow after encountering a cue, forming hypotheses about how the story might develop."@en ;
                             rdfs:label "initiates inferential walk"@en .


###  https://lectoringraphula.org/ontology#isLicensedByInference
lig:isLicensedByInference rdf:type owl:ObjectProperty ;
                          owl:inverseOf lig:licensesInterpretation ;
                          rdfs:domain lig:Interpretation ,
                                      lig:InterpretiveOutcome ,
                                      lig:LicensedInterpretation ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty lig:isLicensedByInference ;
                                        owl:someValuesFrom lig:Inference
                                      ] ;
                          rdfs:range lig:Inference ,
                                     lig:InterpretiveOperation ;
                          <http://purl.org/dc/elements/1.1/description> "Links a licensed interpretation to the inference that licenses it."@en ;
                          rdfs:comment "This property connects a LicensedInterpretation to the Inference that supports or licenses it. It is the inverse relation of licensesInterpretation and is useful for expressing restrictions from the perspective of the interpretive outcome."@en ;
                          rdfs:label "is licensed by inference"@en .


###  https://lectoringraphula.org/ontology#knowledgeSupportsInference
lig:knowledgeSupportsInference rdf:type owl:ObjectProperty ;
                               rdfs:domain lig:InterpretiveResource ,
                                           lig:IntrinsicKnowledge ;
                               rdfs:range lig:Inference ,
                                          lig:InterpretiveOperation ;
                               <http://purl.org/dc/elements/1.1/description> "Relates intrinsic knowledge to an inference that depends on a cue requiring that knowledge."@en ;
                               rdfs:comment "This property is intended to be inferred when a textual cue both requires intrinsic knowledge and supports an inference."@en ;
                               rdfs:label "knowledge supports inference"@en .


###  https://lectoringraphula.org/ontology#licensesInterpretation
lig:licensesInterpretation rdf:type owl:ObjectProperty ;
                           rdfs:domain lig:Inference ,
                                       lig:InterpretiveOperation ;
                           rdfs:range lig:Interpretation ,
                                      lig:InterpretiveOutcome ,
                                      lig:LicensedInterpretation ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty lig:isLicensedByInference ;
                                        owl:someValuesFrom lig:Inference
                                      ] ;
                           <http://purl.org/dc/elements/1.1/description> "Links an inference to the licensed interpretation it produces."@en ;
                           rdfs:comment "This property connects an Inference to a LicensedInterpretation. A licensed interpretation is one that stays within the boundaries set by the Model Author. It is an interpretation that the text legitimately authorizes, as opposed to an arbitrary use of the text."@en ;
                           rdfs:label "licenses interpretation"@en .


###  https://lectoringraphula.org/ontology#opensProbabilityDisjunction
lig:opensProbabilityDisjunction rdf:type owl:ObjectProperty ;
                                rdfs:domain lig:InterpretiveOperation ,
                                            lig:Prediction ;
                                rdfs:range lig:InterpretiveOperation ,
                                           lig:ProbabilityDisjunction ;
                                <http://purl.org/dc/elements/1.1/description> "Links a prediction to the set of alternative possibilities it opens."@en ;
                                rdfs:comment "This property connects a Prediction to a ProbabilityDisjunction. When the reader makes a prediction, they consider a set of alternative narrative developments with different degrees of probability. Eco uses this concept to describe how the reader navigates uncertainty during interpretation."@en ;
                                rdfs:label "opens probability disjunction"@en .


###  https://lectoringraphula.org/ontology#presupposesModelReader
lig:presupposesModelReader rdf:type owl:ObjectProperty ;
                           rdfs:domain lig:Text ,
                                       lig:TextualEntity ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty lig:encodesModelAuthor ;
                                         owl:someValuesFrom lig:ModelAuthor
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty lig:presupposesModelReader ;
                                         owl:someValuesFrom lig:ModelReader
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty lig:requiresCompetence ;
                                         owl:someValuesFrom lig:ReaderCompetence
                                       ] ;
                           rdfs:range lig:ModelReader ,
                                      lig:TextualStrategy ;
                           <http://purl.org/dc/elements/1.1/description> "Links a text to the model reader it presupposes."@en ;
                           rdfs:comment "This property connects a Text to the ModelReader it presupposes. Every text assumes an ideal reader who has the right knowledge and competences to understand it. This reader is not a real person but a strategy built into the text itself."@en ;
                           rdfs:label "presupposes model reader"@en .


###  https://lectoringraphula.org/ontology#producesInterpretation
lig:producesInterpretation rdf:type owl:ObjectProperty ;
                           rdfs:domain lig:InterpretiveOperation ,
                                       lig:SemanticActualization ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty lig:producesInterpretation ;
                                         owl:someValuesFrom lig:Interpretation
                                       ] ;
                           rdfs:range lig:Interpretation ,
                                      lig:InterpretiveOutcome ;
                           <http://purl.org/dc/elements/1.1/description> "Links a semantic actualization to the interpretation it produces."@en ;
                           rdfs:comment "This property connects a SemanticActualization to the Interpretation it produces. Semantic actualization is the process through which the Model Reader transforms textual potential meaning into an actual interpretation."@en ;
                           rdfs:label "produces interpretation"@en .


###  https://lectoringraphula.org/ontology#projectsPossibleWorld
lig:projectsPossibleWorld rdf:type owl:ObjectProperty ;
                          rdfs:domain lig:InterpretiveOperation ,
                                      lig:Prediction ;
                          rdfs:range lig:NarrativeConstruction ,
                                     lig:PossibleWorld ;
                          <http://purl.org/dc/elements/1.1/description> "Links a prediction to the possible world it projects."@en ;
                          rdfs:comment "This property connects a Prediction to a PossibleWorld. When the reader makes a prediction, they mentally construct a possible version of the narrative world. These possible worlds are evaluated for consistency as the reading progresses."@en ;
                          rdfs:label "projects possible world"@en .


###  https://lectoringraphula.org/ontology#reconstructsFabula
lig:reconstructsFabula rdf:type owl:ObjectProperty ;
                       rdfs:domain lig:ModelReader ,
                                   lig:TextualStrategy ;
                       rdfs:range lig:Fabula ,
                                  lig:NarrativeConstruction ;
                       <http://purl.org/dc/elements/1.1/description> "Links the model reader to the fabula it reconstructs."@en ;
                       rdfs:comment "This property connects a ModelReader to the Fabula it reconstructs. The fabula is the chronological sequence of events in the story. It is not given directly by the text but reconstructed by the reader by reordering and connecting narrative events."@en ;
                       rdfs:label "reconstructs fabula"@en .


###  https://lectoringraphula.org/ontology#requiresCompetence
lig:requiresCompetence rdf:type owl:ObjectProperty ;
                       rdfs:domain lig:Text ,
                                   lig:TextualEntity ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty lig:encodesModelAuthor ;
                                     owl:someValuesFrom lig:ModelAuthor
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty lig:presupposesModelReader ;
                                     owl:someValuesFrom lig:ModelReader
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty lig:requiresCompetence ;
                                     owl:someValuesFrom lig:ReaderCompetence
                                   ] ;
                       rdfs:range lig:InterpretiveResource ,
                                  lig:ReaderCompetence ;
                       <http://purl.org/dc/elements/1.1/description> "Links a text to the reader competence it requires."@en ;
                       rdfs:comment "This property connects a Text to the ReaderCompetence it requires. To interpret a text correctly, the reader needs specific linguistic, cultural and encyclopedic knowledge. This property models what the text expects its reader to already know."@en ;
                       rdfs:label "requires competence"@en .


###  https://lectoringraphula.org/ontology#requiresIntrinsicKnowledge
lig:requiresIntrinsicKnowledge rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf lig:activatesResource ;
                               rdfs:domain lig:TextualCue ,
                                           lig:TextualEntity ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty lig:activatesResource ;
                                             owl:someValuesFrom lig:InterpretiveResource
                                           ] ;
                               rdfs:range lig:InterpretiveResource ,
                                          lig:IntrinsicKnowledge ;
                               <http://purl.org/dc/elements/1.1/description> "Links a textual cue to the intrinsic knowledge it requires."@en ;
                               rdfs:comment "This property connects a TextualCue to the IntrinsicKnowledge the reader must have to interpret it correctly. Intrinsic knowledge is not stated explicitly in the text but is assumed to be already known by the reader. It is called intrinsic because it is built into the cooperative structure of the text."@en ;
                               rdfs:label "requires intrinsic knowledge"@en .


###  https://lectoringraphula.org/ontology#supportsInference
lig:supportsInference rdf:type owl:ObjectProperty ;
                      rdfs:domain lig:TextualCue ,
                                  lig:TextualEntity ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty lig:activatesResource ;
                                    owl:someValuesFrom lig:InterpretiveResource
                                  ] ;
                      rdfs:range lig:Inference ,
                                 lig:InterpretiveOperation ;
                      <http://purl.org/dc/elements/1.1/description> "Links a textual cue to the inference it supports."@en ;
                      rdfs:comment "This property connects a TextualCue to the Inference it supports. When the reader activates interpretive resources, they draw inferences that move from what the text says to what it means. This inferential step is at the heart of Eco's cooperative process."@en ;
                      rdfs:label "supports inference"@en .


###  https://lectoringraphula.org/ontology#triggersPresupposition
lig:triggersPresupposition rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf lig:activatesResource ;
                           rdfs:domain lig:TextualCue ,
                                       lig:TextualEntity ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty lig:activatesResource ;
                                         owl:someValuesFrom lig:InterpretiveResource
                                       ] ;
                           rdfs:range lig:InterpretiveResource ,
                                      lig:IntrinsicKnowledge ,
                                      lig:Presupposition ;
                           <http://purl.org/dc/elements/1.1/description> "Links a textual cue to the presupposition it triggers."@en ;
                           rdfs:comment "This property connects a TextualCue to a Presupposition it triggers in the reader. A presupposition is something the text takes for granted without stating it explicitly. For example, a proper name, title, pronoun, or definite expression may presuppose identity, social role, possession, belonging, or previous knowledge."@en ;
                           rdfs:label "triggers presupposition"@en .


#################################################################
#    Data properties
#################################################################

###  https://lectoringraphula.org/ontology#hasAnnotationNote
lig:hasAnnotationNote rdf:type owl:DatatypeProperty ;
                      rdfs:domain owl:Thing ;
                      rdfs:range xsd:string ;
                      <http://purl.org/dc/elements/1.1/description> "Associates an entity with an explanatory annotation note."@en ;
                      rdfs:comment "This data property records a free textual note explaining how an entity is used in the ontology or in a specific interpretive analysis. It is intended for documentation and manual annotation rather than for formal reasoning."@en ;
                      rdfs:label "has annotation note"@en .


###  https://lectoringraphula.org/ontology#hasConfidenceValue
lig:hasConfidenceValue rdf:type owl:DatatypeProperty ;
                       rdfs:domain lig:InterpretiveOperation ;
                       rdfs:range xsd:decimal ;
                       <http://purl.org/dc/elements/1.1/description> "Associates an interpretive operation with a numerical confidence value."@en ;
                       rdfs:comment "This data property connects an InterpretiveOperation to a numerical confidence value. It can be used when an interpretation, prediction, or extraction process needs to express a degree of confidence, especially in later comparison with automatic extraction tools."@en ;
                       rdfs:label "has confidence value"@en .


###  https://lectoringraphula.org/ontology#hasInterpretiveStatus
lig:hasInterpretiveStatus rdf:type owl:DatatypeProperty ;
                          rdfs:domain lig:InterpretiveOutcome ;
                          rdfs:range xsd:string ;
                          <http://purl.org/dc/elements/1.1/description> "Associates an interpretive outcome with a status."@en ;
                          rdfs:comment "This data property connects an InterpretiveOutcome to a qualitative status describing how it relates to the textual strategy. It can be used to indicate whether an outcome is licensed, alternative, rejected, arbitrary, or still uncertain."@en ;
                          rdfs:label "has interpretive status"@en .


###  https://lectoringraphula.org/ontology#hasProbabilityDegree
lig:hasProbabilityDegree rdf:type owl:DatatypeProperty ;
                         rdfs:domain lig:InterpretiveOperation ,
                                     lig:Prediction ;
                         rdfs:range xsd:string ;
                         <http://purl.org/dc/elements/1.1/description> "Associates a prediction with a qualitative probability degree."@en ;
                         rdfs:comment "This data property connects a Prediction to a qualitative degree of probability, such as high, medium, low, or undetermined. It is used to model the different strengths of alternative predictions within a probability disjunction, without introducing formal probabilistic reasoning."@en ;
                         rdfs:label "has probability degree"@en .


###  https://lectoringraphula.org/ontology#hasSequenceNumber
lig:hasSequenceNumber rdf:type owl:DatatypeProperty ;
                      rdfs:domain lig:InterpretiveOperation ;
                      rdfs:range xsd:integer ;
                      <http://purl.org/dc/elements/1.1/description> "Associates an interpretive operation with its order in a sequence."@en ;
                      rdfs:comment "This data property assigns an order number to an InterpretiveOperation. It is useful for representing the sequence of inferences, predictions, and revisions that compose an inferential walk."@en ;
                      rdfs:label "has sequence number"@en .


###  https://lectoringraphula.org/ontology#hasSourceReference
lig:hasSourceReference rdf:type owl:DatatypeProperty ;
                       rdfs:domain lig:TextualEntity ;
                       rdfs:range xsd:string ;
                       <http://purl.org/dc/elements/1.1/description> "Associates a textual entity with a source reference."@en ;
                       rdfs:comment "This data property records a bibliographic or textual reference for a TextualEntity, such as a chapter, section, page, or passage identifier. It is useful for connecting interpretive analysis to the textual location from which it originates."@en ;
                       rdfs:label "has source reference"@en .


###  https://lectoringraphula.org/ontology#hasTextualContent
lig:hasTextualContent rdf:type owl:DatatypeProperty ;
                      rdfs:domain lig:TextualEntity ;
                      rdfs:range xsd:string ;
                      <http://purl.org/dc/elements/1.1/description> "Associates a textual entity with its literal textual content."@en ;
                      rdfs:comment "This data property connects a TextualEntity, such as a TextFragment, TextualCue, or Gap, to a literal string representing its textual content. It is useful for recording the surface form of the textual element analyzed during interpretation."@en ;
                      rdfs:label "has textual content"@en .


#################################################################
#    Classes
#################################################################

###  https://lectoringraphula.org/ontology#AccidentalProperty
lig:AccidentalProperty rdf:type owl:Class ;
                       rdfs:subClassOf lig:NarrativeConstruction ,
                                       lig:WorldProperty ;
                       owl:disjointWith lig:EssentialProperty ;
                       <http://purl.org/dc/elements/1.1/description> "A property that may vary without affecting identity."@en ;
                       rdfs:comment "This class represents a contingent property that can change across possible worlds while preserving the identity of the world individual. Accidental properties account for narrative variations that do not alter the fundamental nature of an entity."@en ;
                       rdfs:label "Accidental Property"@en .


###  https://lectoringraphula.org/ontology#AlternativeInterpretation
lig:AlternativeInterpretation rdf:type owl:Class ;
                              rdfs:subClassOf lig:Interpretation ,
                                              lig:InterpretiveOutcome ;
                              <http://purl.org/dc/elements/1.1/description> "A different but textually compatible interpretation."@en ;
                              rdfs:comment "This class represents an interpretation that differs from another interpretation but remains compatible with the textual strategy. Alternative interpretations are especially relevant for open texts, where the text may organize a plurality of coherent interpretive paths without allowing unlimited or arbitrary meanings."@en ;
                              rdfs:label "Alternative Interpretation"@en .


###  https://lectoringraphula.org/ontology#ClosedText
lig:ClosedText rdf:type owl:Class ;
               rdfs:subClassOf lig:Text ,
                               lig:TextualEntity ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty lig:encodesModelAuthor ;
                                 owl:someValuesFrom lig:ModelAuthor
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty lig:presupposesModelReader ;
                                 owl:someValuesFrom lig:ModelReader
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty lig:requiresCompetence ;
                                 owl:someValuesFrom lig:ReaderCompetence
                               ] ;
               <http://purl.org/dc/elements/1.1/description> "A text that strongly restricts the reader's interpretive path."@en ;
               rdfs:comment "This class represents texts that attempt to guide the reader toward a more controlled or predetermined interpretation. A closed text reduces interpretive freedom by limiting ambiguity and by strongly directing the Model Reader's cooperation."@en ;
               rdfs:label "Closed Text"@en .


###  https://lectoringraphula.org/ontology#Code
lig:Code rdf:type owl:Class ;
         rdfs:subClassOf lig:InterpretiveResource ;
         owl:disjointWith lig:Frame ;
         <http://purl.org/dc/elements/1.1/description> "A system of conventions used to interpret textual signs."@en ;
         rdfs:comment "This class represents a general system of interpretive conventions that allows the Model Reader to assign meaning to textual elements. Codes may include linguistic, cultural, rhetorical, ideological, stylistic, or narrative conventions required by the text."@en ;
         rdfs:label "Code"@en .


###  https://lectoringraphula.org/ontology#CommonFrame
lig:CommonFrame rdf:type owl:Class ;
                rdfs:subClassOf lig:Frame ,
                                lig:InterpretiveResource ;
                <http://purl.org/dc/elements/1.1/description> "A frame based on ordinary or shared background knowledge."@en ;
                rdfs:comment "This class represents a frame grounded in common, everyday, or widely shared knowledge. A common frame allows the Model Reader to interpret textual cues through ordinary expectations about situations, actions, roles, and events."@en ;
                rdfs:label "Common Frame"@en .


###  https://lectoringraphula.org/ontology#EmpiricalAuthor
lig:EmpiricalAuthor rdf:type owl:Class ;
                    rdfs:subClassOf lig:EmpiricalEntity ;
                    owl:disjointWith lig:ModelAuthor ;
                    <http://purl.org/dc/elements/1.1/description> "The real-world author who produces a text."@en ;
                    rdfs:comment "This class represents the empirical author as the historical or real-world person responsible for producing a text. It is distinguished from the Model Author, which is not a person but a textual strategy reconstructed through interpretation."@en ;
                    rdfs:label "Empirical Author"@en .


###  https://lectoringraphula.org/ontology#EmpiricalEntity
lig:EmpiricalEntity rdf:type owl:Class ;
                    <http://purl.org/dc/elements/1.1/description> "A real-world entity involved in the production or reception of a text."@en ;
                    rdfs:comment "This class groups empirical entities such as the empirical author and the empirical reader. It is included in order to distinguish real-world agents from Eco's textual strategies, especially the Model Author and the Model Reader."@en ;
                    rdfs:label "Empirical Entity"@en .


###  https://lectoringraphula.org/ontology#EmpiricalReader
lig:EmpiricalReader rdf:type owl:Class ;
                    rdfs:subClassOf lig:EmpiricalEntity ;
                    owl:disjointWith lig:ModelReader ;
                    <http://purl.org/dc/elements/1.1/description> "A real-world reader who encounters and interprets a text."@en ;
                    rdfs:comment "This class represents an empirical reader as an actual person who reads a text. It is distinguished from the Model Reader, which is the reader role presupposed, constructed, and guided by the text itself."@en ;
                    rdfs:label "Empirical Reader"@en .


###  https://lectoringraphula.org/ontology#Encyclopedia
lig:Encyclopedia rdf:type owl:Class ;
                 rdfs:subClassOf lig:InterpretiveResource ;
                 <http://purl.org/dc/elements/1.1/description> "The cultural and semantic knowledge activated during interpretation."@en ;
                 rdfs:comment "This class represents Eco's concept of encyclopedia as the network of cultural, linguistic, semantic, intertextual, and world knowledge that the Model Reader activates in order to interpret a text. The encyclopedia provides the background from which codes, frames, presuppositions, and intrinsic knowledge can be selected during textual cooperation."@en ;
                 rdfs:label "Encyclopedia"@en .


###  https://lectoringraphula.org/ontology#EncyclopedicPresupposition
lig:EncyclopedicPresupposition rdf:type owl:Class ;
                               rdfs:subClassOf lig:InterpretiveResource ,
                                               lig:IntrinsicKnowledge ;
                               <http://purl.org/dc/elements/1.1/description> "A presupposition based on encyclopedic or cultural knowledge"@en ;
                               rdfs:comment "This class represents a presupposition that depends on encyclopedic, cultural, contextual, intertextual, or world knowledge activated by the Model Reader. It connects the implicit assumptions of the text with the broader encyclopedia required for interpretation."@en ;
                               rdfs:label "Encyclopedic Presupposition"@en .


###  https://lectoringraphula.org/ontology#EssentialProperty
lig:EssentialProperty rdf:type owl:Class ;
                      rdfs:subClassOf lig:NarrativeConstruction ,
                                      lig:WorldProperty ;
                      <http://purl.org/dc/elements/1.1/description> "A property that defines the identity of a world individual."@en ;
                      rdfs:comment "This class represents a property that is constitutive of a world individual's identity across possible worlds. Altering or removing an essential property results in a different individual rather than a different version of the same one."@en ;
                      rdfs:label "Essential Property"@en .


###  https://lectoringraphula.org/ontology#Fabula
lig:Fabula rdf:type owl:Class ;
           rdfs:subClassOf lig:NarrativeConstruction ;
           <http://purl.org/dc/elements/1.1/description> "The chronological sequence of events reconstructed by the Model Reader."@en ;
           rdfs:comment "This class represents the fabula as reconstructed by the Model Reader through interpretive cooperation. Unlike the linear order of the text, the fabula is the coherent sequence of events inferred by reorganizing the textual manifestation according to causal and temporal relations."@en ;
           rdfs:label "Fabula"@en .


###  https://lectoringraphula.org/ontology#Frame
lig:Frame rdf:type owl:Class ;
          rdfs:subClassOf lig:InterpretiveResource ;
          <http://purl.org/dc/elements/1.1/description> "A structured knowledge pattern activated during interpretation."@en ;
          rdfs:comment "This class represents a structured pattern of knowledge used by the Model Reader to organize and interpret a situation, event, role, or textual cue. Frames help the reader connect explicit textual elements with implicit expectations and inferential possibilities."@en ;
          rdfs:label "Frame"@en .


###  https://lectoringraphula.org/ontology#Gap
lig:Gap rdf:type owl:Class ;
        rdfs:subClassOf lig:TextualEntity ;
        <http://purl.org/dc/elements/1.1/description> "An implicit or unsaid element that requires reader cooperation."@en ;
        rdfs:comment "This class represents what the text leaves incomplete, implicit, presupposed, or unsaid. In Eco's theory, gaps are central because the text requires the Model Reader to fill them through interpretive cooperation, using encyclopedic knowledge, codes, frames, and inferences."@en ;
        rdfs:label "Gap"@en .


###  https://lectoringraphula.org/ontology#Inference
lig:Inference rdf:type owl:Class ;
              rdfs:subClassOf lig:InterpretiveOperation ;
              <http://purl.org/dc/elements/1.1/description> "A single interpretive reasoning step."@en ;
              rdfs:comment "This class represents a single interpretive operation through which the Model Reader derives a conclusion from textual cues and activated interpretive resources. An inference connects what is explicitly given by the text with what must be reconstructed, presupposed, or hypothesized during interpretation."@en ;
              rdfs:label "Inference"@en .


###  https://lectoringraphula.org/ontology#InferentialWalk
lig:InferentialWalk rdf:type owl:Class ;
                    rdfs:subClassOf lig:InterpretiveOperation ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty lig:constructsPossibleWorld ;
                                      owl:someValuesFrom lig:PossibleWorld
                                    ] ;
                    <http://purl.org/dc/elements/1.1/description> "A sequence of interpretive movements beyond the linear text."@en ;
                    rdfs:comment "This class represents the broader interpretive path through which the Model Reader moves from the linear manifestation of the text toward possible hypotheses, encyclopedic knowledge, predictions, and possible worlds, before returning to the text for confirmation or revision. An inferential walk is composed of multiple interpretive operations rather than a single inference."@en ;
                    rdfs:label "Inferential Walk"@en .


###  https://lectoringraphula.org/ontology#Interpretation
lig:Interpretation rdf:type owl:Class ;
                   rdfs:subClassOf lig:InterpretiveOutcome ;
                   owl:disjointWith lig:TextualCue ,
                                    lig:Use ;
                   <http://purl.org/dc/elements/1.1/description> "An interpretive result constrained by the text."@en ;
                   rdfs:comment "This class represents an interpretation produced through textual cooperation. In Eco's theory, an interpretation is not an arbitrary projection by an empirical reader, but a result constrained by the textual strategy, the Model Reader, activated codes, frames, intrinsic knowledge, and inferential operations."@en ;
                   rdfs:label "Interpretation"@en .


###  https://lectoringraphula.org/ontology#InterpretiveOperation
lig:InterpretiveOperation rdf:type owl:Class ;
                          <http://purl.org/dc/elements/1.1/description> "An operation performed during textual cooperation."@en ;
                          rdfs:comment "This class represents the dynamic operations through which the Model Reader cooperates with the text, such as inference, prediction, probability disjunction, inferential walk, and semantic actualization. These operations transform textual cues and activated knowledge into interpretive constructions."@en ;
                          rdfs:label "Interpretive Operation"@en .


###  https://lectoringraphula.org/ontology#InterpretiveOutcome
lig:InterpretiveOutcome rdf:type owl:Class ;
                        <http://purl.org/dc/elements/1.1/description> "The result of an interpretive process."@en ;
                        rdfs:comment "This class represents the outcomes produced by interpretive cooperation, including interpretations licensed by the text, alternative interpretations, and uses of the text. It is used to distinguish interpretations constrained by textual strategy from arbitrary uses that go beyond textual cooperation."@en ;
                        rdfs:label "Interpretive Outcome"@en .


###  https://lectoringraphula.org/ontology#InterpretiveResource
lig:InterpretiveResource rdf:type owl:Class ;
                         <http://purl.org/dc/elements/1.1/description> "A resource activated by the Model Reader during interpretation."@en ;
                         rdfs:comment "This class groups the resources that make interpretation possible, such as encyclopedia, codes, subcodes, frames, presuppositions, and intrinsic knowledge. These resources are not necessarily explicit in the text, but they are required for the coherent actualization of meaning."@en ;
                         rdfs:label "Interpretive Resource"@en .


###  https://lectoringraphula.org/ontology#IntertextualFrame
lig:IntertextualFrame rdf:type owl:Class ;
                      rdfs:subClassOf lig:Frame ,
                                      lig:InterpretiveResource ;
                      <http://purl.org/dc/elements/1.1/description> "A frame activated through relations with other texts or genres."@en ;
                      rdfs:comment "This class represents a frame activated by the Model Reader through knowledge of other texts, genres, traditions, narrative conventions, or cultural references. An intertextual frame supports interpretation when a text relies on echoes, allusions, quotations, or genre-based expectations."@en ;
                      rdfs:label "Intertextual Frame"@en .


###  https://lectoringraphula.org/ontology#IntrinsicKnowledge
lig:IntrinsicKnowledge rdf:type owl:Class ;
                       rdfs:subClassOf lig:InterpretiveResource ;
                       <http://purl.org/dc/elements/1.1/description> "Implicit knowledge required for coherent interpretation."@en ;
                       rdfs:comment "This class represents knowledge that is not necessarily explicit on the textual surface, but is internally required by the text for coherent interpretation. Intrinsic knowledge is activated by textual cues and constrained by the textual strategy, allowing the Model Reader to fill gaps, resolve presuppositions, and support inferences."@en ;
                       rdfs:label "Intrinsic Knowledge"@en .


###  https://lectoringraphula.org/ontology#LicensedInterpretation
lig:LicensedInterpretation rdf:type owl:Class ;
                           rdfs:subClassOf lig:Interpretation ,
                                           lig:InterpretiveOutcome ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty lig:isLicensedByInference ;
                                             owl:someValuesFrom lig:Inference
                                           ] ;
                           <http://purl.org/dc/elements/1.1/description> "An interpretation supported by the textual strategy."@en ;
                           rdfs:comment "This class represents an interpretation that is licensed, supported, or authorized by the text. A licensed interpretation is coherent with the textual cues, interpretive resources, inferential paths, and constraints established by the Model Author and activated by the Model Reader."@en ;
                           rdfs:label "Licensed Interpretation"@en .


###  https://lectoringraphula.org/ontology#LinearManifestation
lig:LinearManifestation rdf:type owl:Class ;
                        rdfs:subClassOf lig:TextualEntity ;
                        <http://purl.org/dc/elements/1.1/description> "The sequential surface through which the text is encountered."@en ;
                        rdfs:comment "This class represents the linear order in which the text is materially or semiotically presented to the reader. It corresponds to the textual surface that the Model Reader follows step by step before reconstructing deeper meanings, fabula, possible worlds, and implicit knowledge."@en ;
                        rdfs:label "Linear Manifestation"@en .


###  https://lectoringraphula.org/ontology#ModelAuthor
lig:ModelAuthor rdf:type owl:Class ;
                rdfs:subClassOf lig:TextualStrategy ;
                <http://purl.org/dc/elements/1.1/description> "The textual strategy that organizes the instructions for interpretation."@en ;
                rdfs:comment "This class represents Eco's Model Author as a strategy encoded within the text, not as the empirical person who wrote it. The Model Author organizes the text so that it anticipates a certain form of cooperation, provides interpretive instructions, and constrains the possible meanings that the Model Reader can actualize."@en ;
                rdfs:label "Model Author"@en .


###  https://lectoringraphula.org/ontology#ModelReader
lig:ModelReader rdf:type owl:Class ;
                rdfs:subClassOf lig:TextualStrategy ;
                <http://purl.org/dc/elements/1.1/description> "The reader role presupposed and constructed by the text."@en ;
                rdfs:comment "This class represents Eco's Model Reader as a textual strategy or interpretive role, not as an empirical reader. The Model Reader is the type of reader that the text presupposes, constructs, and guides through its cues, gaps, codes, frames, and inferential paths."@en ;
                rdfs:label "Model Reader"@en .


###  https://lectoringraphula.org/ontology#NarrativeConstruction
lig:NarrativeConstruction rdf:type owl:Class ;
                          <http://purl.org/dc/elements/1.1/description> "A narrative structure constructed through interpretation."@en ;
                          rdfs:comment "This class groups the narrative structures that emerge from interpretive cooperation, such as fabula, possible worlds, reference worlds, world states, world individuals, and world properties. These constructions represent how the Model Reader organizes textual information into coherent narrative worlds."@en ;
                          rdfs:label "Narrative Construction"@en .


###  https://lectoringraphula.org/ontology#NarrativeText
lig:NarrativeText rdf:type owl:Class ;
                  rdfs:subClassOf lig:Text ,
                                  lig:TextualEntity ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty lig:encodesModelAuthor ;
                                    owl:someValuesFrom lig:ModelAuthor
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty lig:presupposesModelReader ;
                                    owl:someValuesFrom lig:ModelReader
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty lig:requiresCompetence ;
                                    owl:someValuesFrom lig:ReaderCompetence
                                  ] ;
                  <http://purl.org/dc/elements/1.1/description> "A text that organizes events, characters, and worlds through narration."@en ;
                  rdfs:comment "This class represents texts that require the reader to reconstruct a narrative sequence, or fabula, through interpretive cooperation. A narrative text guides the Model Reader in connecting textual cues, filling gaps, making inferences, and constructing possible worlds."@en ;
                  rdfs:label "Narrative Text"@en .


###  https://lectoringraphula.org/ontology#OpenText
lig:OpenText rdf:type owl:Class ;
             rdfs:subClassOf lig:Text ,
                             lig:TextualEntity ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty lig:encodesModelAuthor ;
                               owl:someValuesFrom lig:ModelAuthor
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty lig:presupposesModelReader ;
                               owl:someValuesFrom lig:ModelReader
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty lig:requiresCompetence ;
                               owl:someValuesFrom lig:ReaderCompetence
                             ] ;
             <http://purl.org/dc/elements/1.1/description> "A text that allows multiple coherent interpretive paths."@en ;
             rdfs:comment "This class represents texts that strategically leave room for a plurality of interpretations. In Eco's theory, an open text does not allow unlimited interpretation, but organizes several possible interpretive paths that remain constrained by the textual strategy."@en ;
             rdfs:label "Open Text"@en .


###  https://lectoringraphula.org/ontology#PossibleWorld
lig:PossibleWorld rdf:type owl:Class ;
                  rdfs:subClassOf lig:NarrativeConstruction ;
                  <http://purl.org/dc/elements/1.1/description> "A narrative world constructed or hypothesized during interpretation."@en ;
                  rdfs:comment "This class represents one of the possible worlds projected by the text and reconstructed by the Model Reader. Possible worlds provide the framework for evaluating events, characters, hypotheses, and narrative developments throughout the interpretive process."@en ;
                  rdfs:label "Possible World"@en .


###  https://lectoringraphula.org/ontology#Prediction
lig:Prediction rdf:type owl:Class ;
               rdfs:subClassOf lig:InterpretiveOperation ;
               <http://purl.org/dc/elements/1.1/description> "An expectation generated during interpretation."@en ;
               rdfs:comment "This class represents an expectation produced by the Model Reader about what may happen, what may be true, or how the text may develop. In Eco's theory, predictions are linked to the construction of possible worlds and to the reader's active cooperation with the text."@en ;
               rdfs:label "Prediction"@en .


###  https://lectoringraphula.org/ontology#Presupposition
lig:Presupposition rdf:type owl:Class ;
                   rdfs:subClassOf lig:InterpretiveResource ,
                                   lig:IntrinsicKnowledge ;
                   <http://purl.org/dc/elements/1.1/description> "Implicit knowledge assumed by the text."@en ;
                   rdfs:comment "This class represents a form of intrinsic knowledge that the text assumes as already available to the Model Reader. A presupposition is not necessarily stated directly, but it is required in order for a textual fragment, cue, or inference to be interpreted coherently."@en ;
                   rdfs:label "Presupposition"@en .


###  https://lectoringraphula.org/ontology#ProbabilityDisjunction
lig:ProbabilityDisjunction rdf:type owl:Class ;
                           rdfs:subClassOf lig:InterpretiveOperation ;
                           <http://purl.org/dc/elements/1.1/description> "A branching point between alternative interpretive possibilities."@en ;
                           rdfs:comment "This class represents a moment in the interpretive process where the Model Reader considers multiple possible developments, hypotheses, or worlds with different degrees of probability. A probability disjunction does not determine a single interpretation immediately, but opens a set of alternative paths that may later be confirmed, weakened, or rejected by the text."@en ;
                           rdfs:label "Probability Disjunction"@en .


###  https://lectoringraphula.org/ontology#ReaderCompetence
lig:ReaderCompetence rdf:type owl:Class ;
                     rdfs:subClassOf lig:InterpretiveResource ;
                     <http://purl.org/dc/elements/1.1/description> "The competence required by the text from its Model Reader."@en ;
                     rdfs:comment "This class represents the set of linguistic, cultural, narrative, intertextual, and inferential competences presupposed by the text. Reader competence defines what the Model Reader must be able to activate in order to cooperate with the textual strategy and actualize coherent meanings."@en ;
                     rdfs:label "Reader Competence"@en .


###  https://lectoringraphula.org/ontology#ReferenceWorld
lig:ReferenceWorld rdf:type owl:Class ;
                   rdfs:subClassOf lig:NarrativeConstruction ,
                                   lig:PossibleWorld ;
                   <http://purl.org/dc/elements/1.1/description> "The world taken as the interpretive point of reference."@en ;
                   rdfs:comment "This class represents the world against which the Model Reader evaluates the truth conditions of narrative statements. The reference world provides the baseline for comparing alternative possible worlds and assessing the coherence of interpretations generated during textual cooperation."@en ;
                   rdfs:label "Reference World"@en .


###  https://lectoringraphula.org/ontology#SNecessaryProperty
lig:SNecessaryProperty rdf:type owl:Class ;
                       rdfs:subClassOf lig:NarrativeConstruction ,
                                       lig:WorldProperty ;
                       <http://purl.org/dc/elements/1.1/description> "A property that is necessary within a specific world state."@en ;
                       rdfs:comment "This class represents a property that is necessarily true only within a particular world state or narrative situation. Unlike essential properties, S-necessary properties derive their necessity from the conditions holding in a given possible world rather than from the identity of the individual itself."@en ;
                       rdfs:label "S-Necessary Property"@en .


###  https://lectoringraphula.org/ontology#SemanticActualization
lig:SemanticActualization rdf:type owl:Class ;
                          rdfs:subClassOf lig:InterpretiveOperation ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty lig:producesInterpretation ;
                                            owl:someValuesFrom lig:Interpretation
                                          ] ;
                          <http://purl.org/dc/elements/1.1/description> "The process of actualizing meaning through interpretation."@en ;
                          rdfs:comment "This class represents the process through which the Model Reader actualizes the semantic content of the text by connecting textual cues, codes, frames, intrinsic knowledge, inferences, and narrative constructions. Semantic actualization transforms the linear manifestation of the text into an interpreted meaning."@en ;
                          rdfs:label "Semantic Actualization"@en .


###  https://lectoringraphula.org/ontology#Subcode
lig:Subcode rdf:type owl:Class ;
            rdfs:subClassOf lig:Code ,
                            lig:InterpretiveResource ;
            <http://purl.org/dc/elements/1.1/description> "A specific interpretive convention within a broader code."@en ;
            rdfs:comment "This class represents a more specific interpretive convention activated in a particular textual, cultural, rhetorical, ideological, stylistic, or intertextual context. A subcode refines a broader code and helps constrain the interpretation of specific textual cues."@en ;
            rdfs:label "Subcode"@en .


###  https://lectoringraphula.org/ontology#Text
lig:Text rdf:type owl:Class ;
         rdfs:subClassOf lig:TextualEntity ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty lig:encodesModelAuthor ;
                           owl:someValuesFrom lig:ModelAuthor
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty lig:presupposesModelReader ;
                           owl:someValuesFrom lig:ModelReader
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty lig:requiresCompetence ;
                           owl:someValuesFrom lig:ReaderCompetence
                         ] ;
         <http://purl.org/dc/elements/1.1/description> "A semiotic object that guides interpretive cooperation."@en ;
         rdfs:comment "This class represents the text as a structured semiotic object that does not simply transmit information, but organizes the conditions for its own interpretation. In Eco's theory, a text is a \"lazy machine\" that requires the cooperation of a Model Reader in order to actualize what is implicit, presupposed, or left unsaid."@en ;
         rdfs:label "Text"@en .


###  https://lectoringraphula.org/ontology#TextFragment
lig:TextFragment rdf:type owl:Class ;
                 rdfs:subClassOf lig:TextualEntity ;
                 <http://purl.org/dc/elements/1.1/description> "A portion of a text relevant for interpretation."@en ;
                 rdfs:comment "This class represents a selected portion of a text that can contain cues, gaps, presuppositions, or other elements relevant to interpretive cooperation. A text fragment can be used to analyze how local textual elements activate broader interpretive resources."@en ;
                 rdfs:label "Text Fragment"@en .


###  https://lectoringraphula.org/ontology#TextualCue
lig:TextualCue rdf:type owl:Class ;
               rdfs:subClassOf lig:TextualEntity ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty lig:activatesResource ;
                                 owl:someValuesFrom lig:InterpretiveResource
                               ] ;
               <http://purl.org/dc/elements/1.1/description> "A textual element that activates interpretation."@en ;
               rdfs:comment "This class represents an element of the text that prompts the Model Reader to activate codes, frames, presuppositions, intrinsic knowledge, or inferences. A textual cue can be a word, expression, stylistic feature, narrative detail, omission, or structural signal."@en ;
               rdfs:label "Textual Cue"@en .


###  https://lectoringraphula.org/ontology#TextualEntity
lig:TextualEntity rdf:type owl:Class ;
                  <http://purl.org/dc/elements/1.1/description> "An entity belonging to the structure or manifestation of a text."@en ;
                  rdfs:comment "This class groups the elements that constitute the textual level of Eco's theory of interpretive cooperation, such as texts, fragments, cues, gaps, and linear manifestations. These entities provide the material basis from which the Model Reader begins the interpretive process."@en ;
                  rdfs:label "Textual Entity"@en .


###  https://lectoringraphula.org/ontology#TextualStrategy
lig:TextualStrategy rdf:type owl:Class ;
                    <http://purl.org/dc/elements/1.1/description> "A strategy encoded by the text to guide and constrain interpretation."@en ;
                    rdfs:comment "This class represents Eco's idea that both the Model Author and the Model Reader are not empirical persons, but textual strategies. A textual strategy organizes the conditions of interpretation by anticipating a competent reader and by providing instructions, limits, and possibilities for textual cooperation."@en ;
                    rdfs:label "Textual Strategy"@en .


###  https://lectoringraphula.org/ontology#Use
lig:Use rdf:type owl:Class ;
        rdfs:subClassOf lig:InterpretiveOutcome ;
        <http://purl.org/dc/elements/1.1/description> "An appropriation of the text beyond its interpretive constraints."@en ;
        rdfs:comment "This class represents Eco's distinction between interpretation and use. A use occurs when a reader appropriates the text for purposes or meanings that are not sufficiently constrained by the textual strategy. Unlike interpretation, use is not modeled as an outcome licensed by the Model Reader's cooperation with the text."@en ;
        rdfs:label "Use"@en .


###  https://lectoringraphula.org/ontology#WorldIndividual
lig:WorldIndividual rdf:type owl:Class ;
                    rdfs:subClassOf lig:NarrativeConstruction ;
                    <http://purl.org/dc/elements/1.1/description> "An entity existing within a possible world."@en ;
                    rdfs:comment "This class represents an individual inhabiting a possible world, such as a character, object, or other narrative entity. World individuals are characterized by properties whose variation across possible worlds allows the Model Reader to reason about identity and narrative consistency."@en ;
                    rdfs:label "World Individual"@en .


###  https://lectoringraphula.org/ontology#WorldProperty
lig:WorldProperty rdf:type owl:Class ;
                  rdfs:subClassOf lig:NarrativeConstruction ;
                  <http://purl.org/dc/elements/1.1/description> "A characteristic attributed to a world individual."@en ;
                  rdfs:comment "This class represents the properties assigned to world individuals within Eco's theory of possible worlds. These properties contribute to defining the identity and state of individuals and are distinguished into essential, accidental, and S-necessary properties according to their interpretive role."@en ;
                  rdfs:label "World Property"@en .


###  https://lectoringraphula.org/ontology#WorldState
lig:WorldState rdf:type owl:Class ;
               rdfs:subClassOf lig:NarrativeConstruction ;
               <http://purl.org/dc/elements/1.1/description> "A specific configuration of a possible world at a given moment."@en ;
               rdfs:comment "This class represents a particular state of affairs within a possible world. A world state consists of the individuals, events, and properties that hold at a specific point in the narrative, allowing the Model Reader to evaluate changes, predictions, and hypothetical developments."@en ;
               rdfs:label "World State"@en .


[ swrl:argument1 var:cue ;
  swrl:argument2 var:inference ;
  swrl:propertyPredicate lig:supportsInference
] .

[ swrl:argument1 var:fragment ;
   swrl:argument2 var:cue ;
   swrl:propertyPredicate lig:containsCue
 ] .

[ swrl:argument1 var:cue ;
   swrl:argument2 var:interpretation ;
   swrl:propertyPredicate lig:contributesToInterpretation
 ] .

[ swrl:argument1 var:fragment ;
   swrl:argument2 var:inference ;
   swrl:propertyPredicate lig:groundsInference
 ] .

[ swrl:argument1 var:knowledge ;
   swrl:argument2 var:inference ;
   swrl:propertyPredicate lig:knowledgeSupportsInference
 ] .

[ swrl:argument1 var:cue ;
   swrl:argument2 var:knowledge ;
   swrl:propertyPredicate lig:requiresIntrinsicKnowledge
 ] .

[ swrl:argument1 var:cue ;
   swrl:argument2 var:inference ;
   swrl:propertyPredicate lig:supportsInference
 ] .

[ swrl:argument1 var:cue ;
   swrl:argument2 var:inference ;
   swrl:propertyPredicate lig:supportsInference
 ] .

[ swrl:argument1 var:inference ;
   swrl:argument2 var:interpretation ;
   swrl:propertyPredicate lig:licensesInterpretation
 ] .

#################################################################
#    Annotations
#################################################################

lig:R1_fragment_grounds_inference swrl:body [ ] ;
swrl:head [ ] .


lig:R2_cue_contributes_to_interpretation swrl:body [ ] ;
swrl:head [ ] .


lig:R3_knowledge_supports_inference swrl:body [ ] ;
swrl:head [ ] .


#################################################################
#    Rules
#################################################################

lig:fragment rdf:type swrl:Variable .

lig:cue rdf:type swrl:Variable .

lig:inference rdf:type swrl:Variable .

lig:interpretation rdf:type swrl:Variable .

lig:knowledge rdf:type swrl:Variable .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "If a textual fragment contains a cue and that cue supports an inference, then the fragment grounds that inference." ;
   rdfs:label "R1FragmentGroundsInference" ;
   rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate lig:containsCue ;
                           swrl:argument1 lig:fragment ;
                           swrl:argument2 lig:cue
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                      swrl:propertyPredicate lig:supportsInference ;
                                      swrl:argument1 lig:cue ;
                                      swrl:argument2 lig:inference
                                    ] ;
                          rdf:rest rdf:nil
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate lig:groundsInference ;
                           swrl:argument1 lig:fragment ;
                           swrl:argument2 lig:inference
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "If a textual cue supports an inference and that inference licenses an interpretation, then the cue contributes to that interpretation." ;
   rdfs:label "R2CueContributesToInterpretation" ;
   rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate lig:supportsInference ;
                           swrl:argument1 lig:cue ;
                           swrl:argument2 lig:inference
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                      swrl:propertyPredicate lig:licensesInterpretation ;
                                      swrl:argument1 lig:inference ;
                                      swrl:argument2 lig:interpretation
                                    ] ;
                          rdf:rest rdf:nil
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate lig:contributesToInterpretation ;
                           swrl:argument1 lig:cue ;
                           swrl:argument2 lig:interpretation
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "If a textual cue requires intrinsic knowledge and supports an inference, then that intrinsic knowledge supports the inference." ;
   rdfs:label "R3KnowledgeSupportsInference" ;
   rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate lig:requiresIntrinsicKnowledge ;
                           swrl:argument1 lig:cue ;
                           swrl:argument2 lig:knowledge
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                      swrl:propertyPredicate lig:supportsInference ;
                                      swrl:argument1 lig:cue ;
                                      swrl:argument2 lig:inference
                                    ] ;
                          rdf:rest rdf:nil
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate lig:knowledgeSupportsInference ;
                           swrl:argument1 lig:knowledge ;
                           swrl:argument2 lig:inference
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

